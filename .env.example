# 复制为 .env 或直接在启动命令前导出环境变量。
# 支持 OpenAI-compatible Chat Completions API。

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1
OPENAI_MODEL_OPTIONS=gpt-4.1,gpt-4.1-mini,gpt-4o,o3,o4-mini

# 是否允许团队成员在页面里覆盖模型设置。
ALLOW_MODEL_CONFIG=true
ALLOW_CLIENT_API_KEY=false
ALLOW_CLIENT_BASE_URL=false

# 可选：Supabase 云端项目存储。
# 当 SUPABASE_URL 和 SUPABASE_SECRET_KEY 都填写时，/api/projects 将改用 Supabase Postgres。
# 这里的 key 必须是服务端专用的 service_role / secret key，绝不能暴露给浏览器。
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# 可选：仅跨域部署前端时填写可信 Origin。生产环境留空默认不允许跨域。
CORS_ORIGIN=

# 服务监听。上线部署时 HOST 通常用 0.0.0.0；本地可保持 127.0.0.1。
PORT=4174
HOST=127.0.0.1

# 可选：团队访问保护。仅当 ENABLE_AUTH=true 且填写 APP_PASSWORD 时，浏览器才会要求登录。
ENABLE_AUTH=false
APP_USER=team
APP_PASSWORD=

# 可选：真实模型冒烟测试的连续运行次数。正式 P1 验证使用 5。
SMOKE_RUNS=1
