# 复制为 .env 或直接在启动命令前导出环境变量。
# 支持 OpenAI-compatible Chat Completions API。

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1
OPENAI_MODEL_OPTIONS=gpt-4.1,gpt-4.1-mini,gpt-4o,o3,o4-mini

# 是否允许团队成员在页面里覆盖模型设置。
ALLOW_MODEL_CONFIG=true
ALLOW_CLIENT_API_KEY=false
ALLOW_CLIENT_BASE_URL=false

# 服务监听。上线部署时 HOST 通常用 0.0.0.0；本地可保持 127.0.0.1。
PORT=4174
HOST=127.0.0.1

# 可选：团队访问保护。填 APP_PASSWORD 后，浏览器会要求输入用户名和密码。
APP_USER=team
APP_PASSWORD=

# 可选：真实模型冒烟测试的连续运行次数。正式 P1 验证使用 5。
SMOKE_RUNS=1
