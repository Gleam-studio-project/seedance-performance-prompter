{
  "version": 2,
  "functions": {
    "api/[...path].js": {
      "maxDuration": 60,
      "includeFiles": "{SKILL.md,references/**,examples/**}"
    }
  },
  "rewrites": [
    {
      "source": "/healthz",
      "destination": "/api/healthz"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "no-referrer" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data:; connect-src 'self'; frame-ancestors 'none'; base-uri 'none'; form-action 'self'" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "ALLOW_MODEL_CONFIG": "true",
    "ALLOW_CLIENT_API_KEY": "false",
    "ALLOW_CLIENT_BASE_URL": "false",
    "OPENAI_MODEL_OPTIONS": "gpt-4.1,gpt-4.1-mini,gpt-4o,o3,o4-mini"
  }
}
